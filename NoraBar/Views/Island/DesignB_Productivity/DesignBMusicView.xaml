<UserControl x:Class="NoraBar.Views.Island.DesignB_Productivity.DesignBMusicView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:NoraBar.Views.Controls"
             xmlns:commonControls="clr-namespace:NoraBar.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="120" d:DesignWidth="560">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="DesignBTitleText" TargetType="TextBlock" BasedOn="{StaticResource TitleText}">
            <Setter Property="FontSize" Value="18" />
        </Style>
        <Style x:Key="DesignBCaptionText" TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
            <Setter Property="FontSize" Value="14" />
        </Style>
    </UserControl.Resources>
    
    <Border Style="{StaticResource IslandBorderStyle}" Padding="16" MouseWheel="UserControl_MouseWheel">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Album Art & Session Dots -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Center">
                    <Grid Width="80" Height="80" Tag="{Binding Music.Title, NotifyOnTargetUpdated=True}">
                        <Grid.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" CenterX="40" CenterY="40" />
                        </Grid.RenderTransform>
                        <Grid.Triggers>
                            <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.5" To="1" Duration="0:0:0.3" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.8" To="1" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.5" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.8" To="1" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.5" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Grid.Triggers>

                        <Border Background="#20FFFFFF" CornerRadius="10" />
                        <TextBlock Text="&#xE8D6;" FontFamily="{StaticResource DefaultFontFamily}" FontSize="28" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Border CornerRadius="10">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding Music.AlbumArt}" Stretch="UniformToFill" />
                            </Border.Background>
                        </Border>
                    </Grid>

                    <!-- Dot Indicator -->
                    <ItemsControl ItemsSource="{Binding Music.SessionDots}" HorizontalAlignment="Center" Margin="0,8,0,0" Visibility="{Binding Music.HasMultipleSessions, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="6" Height="6" CornerRadius="3" Margin="3,0" Background="{StaticResource AccentBrush}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Opacity" Value="0.3" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Opacity" Value="1.0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Metadata -->
                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel.RenderTransform>
                            <TranslateTransform Y="0"/>
                        </StackPanel.RenderTransform>
                        <StackPanel.Triggers>
                            <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="10" To="0" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </StackPanel.Triggers>
                        <commonControls:MarqueeTextBlock Text="{Binding Music.Title, NotifyOnTargetUpdated=True}" TextStyle="{StaticResource DesignBTitleText}" Margin="0,0,0,4" TextTrimming="CharacterEllipsis" ScrollMode="{Binding Music.TextScrollMode}"/>
                        <commonControls:MarqueeTextBlock Text="{Binding Music.Artist}" TextStyle="{StaticResource DesignBCaptionText}" TextTrimming="CharacterEllipsis" ScrollMode="{Binding Music.TextScrollMode}"/>
                    </StackPanel>
                    
                    <controls:WaveformVisualizer Grid.Column="1" Margin="16,0,0,0" SpectrumData="{Binding Music.SpectrumData}" BarColor="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                </Grid>

                <!-- Controls -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" MinWidth="180" Margin="24,0,0,0" Height="80">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <controls:IconButton IconText="&#xE892;" Margin="0,0,8,0" Command="{Binding Music.PreviousCommand}" /> <!-- Previous -->
                        
                        <!-- Play/Pause Button styled with Design A to unify aesthetics -->
                        <controls:IconButton IconText="{Binding Music.IsPlaying, Converter={StaticResource PlayPauseIconConverter}}" Margin="0,0,8,0" Command="{Binding Music.PlayPauseCommand}" /> <!-- Play/Pause -->
                        
                        <controls:IconButton IconText="&#xE893;" Command="{Binding Music.NextCommand}" /> <!-- Next -->
                    </StackPanel>
                    <Grid Margin="0,12,0,0" Visibility="{Binding ShowProgressBar, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Music.PositionText}" Style="{StaticResource CaptionText}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                        <ProgressBar Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Music.ProgressValue}" Height="4" Foreground="{StaticResource AccentBrush}" Background="#33FFFFFF" BorderThickness="0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding Music.DurationText}" Style="{StaticResource CaptionText}" Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Lyrics Row (Shown when ShowLyrics is true) -->
            <TextBlock Grid.Row="1"
                       Margin="0,12,0,0"
                       Height="20"
                       Text="{Binding Music.CurrentLyric, NotifyOnTargetUpdated=True}"
                       Foreground="#E0FFFFFF"
                       FontSize="14"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Visibility="{Binding ShowLyrics, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock.RenderTransform>
                    <TranslateTransform Y="0"/>
                </TextBlock.RenderTransform>
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="Binding.TargetUpdated">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="5" To="0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>
        </Grid>
    </Border>
</UserControl>

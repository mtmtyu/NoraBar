<Window x:Class="NoraBar.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:NoraBar.Models"
        xmlns:converters="clr-namespace:NoraBar.Converters"
        mc:Ignorable="d"
        Title="{Binding SettingsWindowTitle}" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="True"
        DataContextChanged="Window_DataContextChanged"
        Closing="Window_Closing"
        FontFamily="Segoe UI, Yu Gothic UI, Meiryo"
        Icon="/Assets/AppIcon.ico">

    <Window.Resources>
        <!-- クローズ用 Storyboard -->
        <Storyboard x:Key="WindowCloseStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="Opacity"
                             To="0.0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                             To="0.95" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                             To="0.95" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <converters:PageToVisibilityConverter x:Key="PageToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Fluent Toggle Switch Style using CheckBox -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="TemplateRoot" Background="Transparent" Cursor="Hand">
                            <Border x:Name="SwitchArea" Width="44" Height="20" Background="#33FFFFFF" CornerRadius="10" BorderBrush="#20FFFFFF" BorderThickness="1">
                                <Ellipse x:Name="Thumb" Width="12" Height="12" Fill="#E3E3E3" HorizontalAlignment="Left" Margin="3,0,3,0">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform X="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchArea" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="SwitchArea" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="White"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="24" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CircleEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CircleEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Thumb" Property="Fill" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Dark Theme Styles -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontFamily" Value="Segoe UI, Yu Gothic UI, Meiryo"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                x:Name="Brd">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="1"
                                                           Text="&#xE70D;"
                                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                           Foreground="#88FFFFFF"
                                                           FontSize="8"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Brd" Property="Background" Value="#25FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,3,30,3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                            <Popup Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#1F1F1F"
                                            BorderBrush="#30FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Margin="0,2,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.4" Color="Black"/>
                                        </Border.Effect>
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel x:Name="ItemsPresenter" IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontFamily" Value="Segoe UI, Yu Gothic UI, Meiryo"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Brd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="3" Margin="2,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Brd" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Brd" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Setting Card Border Style -->
        <Style x:Key="SettingCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#0DFFFFFF" />
            <Setter Property="BorderBrush" Value="#10FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <!-- Typography styles -->
        <Style x:Key="CardHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Yu Gothic UI, Meiryo" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F5F5F5" />
        </Style>

        <Style x:Key="CardSubHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Yu Gothic UI, Meiryo" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#8A8A8A" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>

        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8AFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" x:Name="Brd">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Brd" Property="Background" Value="#10FFFFFF" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ページ切り替えアニメーション用スタイル -->
        <Style TargetType="ScrollViewer" x:Key="AnimatedPageStyle">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="15" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 背景フェードイン -->
        <Storyboard x:Key="OverlayFadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1.0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <!-- 背景フェードアウト -->
        <Storyboard x:Key="OverlayFadeOutStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.0" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <!-- ダイアログ表示ポップアップ -->
        <Storyboard x:Key="DialogOpenStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.85" To="1.0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="0.3" EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.85" To="1.0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="0.3" EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     To="1.0" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="RootBorder"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                     To="1.0" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="RootBorder"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                     To="1.0" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <!-- Background and Window Border -->
        <Border x:Name="RootBorder" Opacity="0" Background="#E01F1F1F" CornerRadius="12" BorderBrush="#30FFFFFF" BorderThickness="1" Padding="24" MouseLeftButtonDown="Header_MouseLeftButtonDown" RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="WindowScale" ScaleX="0.95" ScaleY="0.95"/>
                    <TranslateTransform x:Name="WindowTranslation" Y="0"/>
                </TransformGroup>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="10" Opacity="0.5" Color="Black" />
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" /> <!-- Sidebar (Left) -->
                    <ColumnDefinition Width="1" />   <!-- Separator 1 -->
                    <ColumnDefinition>
                        <ColumnDefinition.Style>
                            <Style TargetType="ColumnDefinition">
                                <Setter Property="Width" Value="430" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="About">
                                        <Setter Property="Width" Value="*" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ColumnDefinition.Style>
                    </ColumnDefinition>
                    <ColumnDefinition>
                        <ColumnDefinition.Style>
                            <Style TargetType="ColumnDefinition">
                                <Setter Property="Width" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="About">
                                        <Setter Property="Width" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ColumnDefinition.Style>
                    </ColumnDefinition>
                    <ColumnDefinition>
                        <ColumnDefinition.Style>
                            <Style TargetType="ColumnDefinition">
                                <Setter Property="Width" Value="*" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="About">
                                        <Setter Property="Width" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ColumnDefinition.Style>
                    </ColumnDefinition>
                </Grid.ColumnDefinitions>

                <!-- Column 0: Sidebar Navigation -->
                <Grid Grid.Column="0" Margin="0,0,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- App Logo / Title -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,24" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown" Orientation="Horizontal">
                        <Image Source="/Assets/AppIcon.ico" Width="32" Height="32" Margin="0,0,12,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="NoraBar" FontSize="20" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI Variable, Segoe UI"/>
                            <TextBlock Text="{Binding AppSubtitleText}" FontSize="11" Foreground="#8A8A8A" Margin="0,2,0,0" FontFamily="Segoe UI Variable, Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Navigation Items -->
                    <StackPanel Grid.Row="1">
                        <!-- HUD Settings -->
                        <Button Command="{Binding NavigateCommand}" CommandParameter="HUD" Style="{StaticResource SidebarButtonStyle}">
                            <Grid Width="160">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="HudIndicator" Grid.Column="0" Width="3" Height="16" CornerRadius="1.5" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window}}" Value="HUD">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <TextBlock Grid.Column="1" Text="&#xE7F4;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#8AFFFFFF"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window}}" Value="HUD">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Grid.Column="2" Text="{Binding HudSettingsText}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#8AFFFFFF"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window}}" Value="HUD">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Button>

                        <!-- About -->
                        <Button Command="{Binding NavigateCommand}" CommandParameter="About" Style="{StaticResource SidebarButtonStyle}">
                            <Grid Width="160">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="AboutIndicator" Grid.Column="0" Width="3" Height="16" CornerRadius="1.5" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window}}" Value="About">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <TextBlock Grid.Column="1" Text="&#xE946;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#8AFFFFFF"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window}}" Value="About">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Grid.Column="2" Text="{Binding AboutText}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#8AFFFFFF"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.CurrentPage, RelativeSource={RelativeSource AncestorType=Window}}" Value="About">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Column 1: Vertical Separator 1 -->
                <Border Grid.Column="1" Width="1" Background="#20FFFFFF" VerticalAlignment="Stretch" Margin="0,0,20,0"/>

                <!-- Column 2: Center Settings Panel -->
                <Grid Grid.Column="2" Margin="0,0,16,0">
                    <Grid.Resources>
                        <Storyboard x:Key="FadeInPage">
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                            </ObjectAnimationUsingKeyFrames>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1.0" Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                        <Storyboard x:Key="FadeOutPage">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.0" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseIn"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="15" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseIn"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.15">
                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                            </ObjectAnimationUsingKeyFrames>
                        </Storyboard>
                    </Grid.Resources>
                    <!-- HUD Settings Page -->
                    <ScrollViewer>
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer" BasedOn="{StaticResource AnimatedPageStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="HUD">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Storyboard="{StaticResource FadeInPage}" />
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard Storyboard="{StaticResource FadeOutPage}" />
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding HudSettingsText}" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,20" FontFamily="Segoe UI Variable, Segoe UI"/>

                            <!-- Card 1: Design Style -->
                            <Border Style="{StaticResource SettingCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding DesignStyleText}" Style="{StaticResource CardHeaderStyle}" />
                                        <TextBlock Text="{Binding DesignStyleDescriptionText}" Style="{StaticResource CardSubHeaderStyle}" />
                                    </StackPanel>

                                    <ComboBox Grid.Column="1"
                                              SelectedValue="{Binding CurrentVariant}"
                                              SelectedValuePath="Tag"
                                              Width="160"
                                              Height="32"
                                              VerticalAlignment="Center">
                                        <ComboBoxItem Content="Minimal (Design A)" Tag="{x:Static models:DesignVariant.MinimalFloatingPill}"/>
                                        <ComboBoxItem Content="Productivity (Design B)" Tag="{x:Static models:DesignVariant.ProductivityCommandIsland}"/>
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- Card 2: Progress Bar Toggle -->
                            <Border Style="{StaticResource SettingCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ProgressBarText}" Style="{StaticResource CardHeaderStyle}" />
                                        <TextBlock Text="{Binding ProgressBarDescriptionText}" Style="{StaticResource CardSubHeaderStyle}" />
                                    </StackPanel>

                                    <CheckBox Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              IsChecked="{Binding ShowProgressBar}"
                                              VerticalAlignment="Center"/>

                                </Grid>
                            </Border>

                            <!-- Card 2.5: Lyrics Toggle -->
                            <Border Style="{StaticResource SettingCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ShowLyricsText}" Style="{StaticResource CardHeaderStyle}" />
                                        <TextBlock Text="{Binding ShowLyricsDescriptionText}" Style="{StaticResource CardSubHeaderStyle}" />
                                    </StackPanel>

                                    <CheckBox Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              IsChecked="{Binding ShowLyrics}"
                                              VerticalAlignment="Center"/>

                                </Grid>
                            </Border>
                            
                            <!-- Card 2.6: Text Scroll Mode -->
                            <Border Style="{StaticResource SettingCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding TextScrollModeText}" Style="{StaticResource CardHeaderStyle}" />
                                        <TextBlock Text="{Binding TextScrollModeDescriptionText}" Style="{StaticResource CardSubHeaderStyle}" />
                                    </StackPanel>

                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailableScrollModes}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding TextScrollMode}"
                                              SelectedValuePath="Mode"
                                              Width="160"
                                              Height="32"
                                              VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <!-- Card 3: Startup Toggle -->
                            <Border Style="{StaticResource SettingCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StartupText}" Style="{StaticResource CardHeaderStyle}" />
                                        <TextBlock Text="{Binding StartupDescriptionText}" Style="{StaticResource CardSubHeaderStyle}" />
                                    </StackPanel>

                                    <CheckBox Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              IsChecked="{Binding IsStartupEnabled}"
                                              VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Card 4: Language Selector -->
                            <Border Style="{StaticResource SettingCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding LanguageText}" Style="{StaticResource CardHeaderStyle}" />
                                        <TextBlock Text="{Binding LanguageDescriptionText}" Style="{StaticResource CardSubHeaderStyle}" />
                                    </StackPanel>

                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailableLanguages}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding SelectedLanguage}"
                                              SelectedValuePath="Language"
                                              Width="160"
                                              Height="32"
                                              VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <!-- Card 5: Window Position -->
                            <Border Style="{StaticResource SettingCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding WindowPositionText}" Style="{StaticResource CardHeaderStyle}" />
                                        <TextBlock Text="{Binding WindowPositionDescriptionText}" Style="{StaticResource CardSubHeaderStyle}" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Command="{Binding ResetPositionCommand}"
                                            Content="{Binding ResetPositionText}"
                                            Visibility="{Binding HasCustomPosition, Converter={StaticResource BoolToVis}}"
                                            Background="#1AFFFFFF" Foreground="White" BorderBrush="#20FFFFFF" BorderThickness="1"
                                            Padding="10,5" Margin="0,0,8,0" VerticalAlignment="Center" Height="32">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" x:Name="Brd">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Brd" Property="Background" Value="#25FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <ToggleButton Grid.Column="2"
                                                  IsChecked="{Binding IsPositionEditMode}"
                                                  Background="#1AFFFFFF" Foreground="White" BorderBrush="#20FFFFFF" BorderThickness="1"
                                                  Padding="10,5" VerticalAlignment="Center" Height="32">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" x:Name="Brd">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Brd" Property="Background" Value="#25FFFFFF"/>
                                                                </Trigger>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Brd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                                                    <Setter TargetName="Brd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                        <ToggleButton.Content>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding DataContext.ChangePositionText, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPositionEditMode}" Value="True">
                                                                <Setter Property="Text" Value="{Binding DataContext.FinishPositionEditText, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </ToggleButton.Content>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <!-- Card 6: Reset Settings -->
                            <Border Style="{StaticResource SettingCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding ResetSettingsText}" Style="{StaticResource CardHeaderStyle}" Foreground="#FF6B6B" />
                                        <TextBlock Text="{Binding ResetSettingsDescriptionText}" Style="{StaticResource CardSubHeaderStyle}" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Command="{Binding ShowResetDialogCommand}"
                                            Content="{Binding ResetAllSettingsText}"
                                            Background="#2A1A1A" Foreground="#FF6B6B" BorderBrush="#3A2020" BorderThickness="1"
                                            Padding="10,5" VerticalAlignment="Center" Height="32">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" x:Name="Brd">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Brd" Property="Background" Value="#3D2020"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- About Page -->
                    <ScrollViewer>
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer" BasedOn="{StaticResource AnimatedPageStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPage}" Value="About">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Storyboard="{StaticResource FadeInPage}" />
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard Storyboard="{StaticResource FadeOutPage}" />
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding AboutText}" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,20" FontFamily="Segoe UI Variable, Segoe UI"/>

                            <!-- Card: Product Info -->
                            <Border Style="{StaticResource SettingCardStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Assets/AppIcon.ico" Width="48" Height="48" Margin="0,0,16,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="NoraBar" FontSize="20" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI Variable, Segoe UI" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding VersionText}" Foreground="#8A8A8A" FontSize="12" FontFamily="Segoe UI Variable, Segoe UI"/>
                                            <TextBlock Text="{Binding CurrentVersion}" Foreground="#8A8A8A" FontSize="12" FontFamily="Segoe UI Variable, Segoe UI"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Card: Check Update -->
                            <Border Style="{StaticResource SettingCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding CheckUpdatesText}" Style="{StaticResource CardHeaderStyle}" />
                                        <TextBlock Text="{Binding CheckUpdatesDescriptionText}" Style="{StaticResource CardSubHeaderStyle}" />
                                    </StackPanel>

                                    <Button Grid.Column="1" Content="{Binding CheckUpdatesButtonText}" Command="{Binding CheckUpdateCommand}" Width="140" Height="32" VerticalAlignment="Center" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#1AFFFFFF" CornerRadius="4" x:Name="Brd">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Brd" Property="Background" Value="#25FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Card: GitHub Repository Link -->
                            <Border Style="{StaticResource SettingCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding GitHubRepositoryText}" Style="{StaticResource CardHeaderStyle}" />
                                        <TextBlock Text="{Binding GitHubRepositoryDescriptionText}" Style="{StaticResource CardSubHeaderStyle}" />
                                    </StackPanel>

                                    <Button Grid.Column="1" Content="{Binding OpenRepositoryText}" Command="{Binding OpenGitHubCommand}" Width="140" Height="32" VerticalAlignment="Center" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#1AFFFFFF" CornerRadius="4" x:Name="Brd">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Brd" Property="Background" Value="#25FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Card: License Info -->
                            <Border Style="{StaticResource SettingCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding OpenSourceLicensesText}" Style="{StaticResource CardHeaderStyle}" />
                                        <TextBlock Text="{Binding OpenSourceLicensesDescriptionText}" Style="{StaticResource CardSubHeaderStyle}" />
                                    </StackPanel>

                                    <Button Grid.Column="1" Content="{Binding ShowLicensesText}" Command="{Binding ShowLicenseCommand}" Width="140" Height="32" VerticalAlignment="Center" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#1AFFFFFF" CornerRadius="4" x:Name="Brd">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Brd" Property="Background" Value="#25FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Column 3: Vertical Separator 2 -->
                <Border Grid.Column="3" Width="1" Background="#20FFFFFF" VerticalAlignment="Stretch" Margin="0,0,20,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentPage}" Value="About">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Column 4: Right Live Preview Panel -->
                <Grid Grid.Column="4">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentPage}" Value="About">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header block -->
                    <Grid Grid.Row="0" Margin="0,0,0,20" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                        <TextBlock Text="{Binding LivePreviewText}" FontSize="16" FontWeight="SemiBold" Foreground="White" FontFamily="Segoe UI, Yu Gothic UI, Meiryo"/>
                    </Grid>

                    <!-- Preview Area with Simulated Desktop Backdrop -->
                    <Border Grid.Row="1" CornerRadius="8" BorderThickness="1" BorderBrush="#20FFFFFF" ClipToBounds="True">
                        <Grid>
                            <!-- Simulated Wallpaper -->
                            <Border CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#08101C" Offset="0"/>
                                        <GradientStop Color="#003554" Offset="0.5"/>
                                        <GradientStop Color="#005F73" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <TextBlock Text="PREVIEW" FontSize="10" FontWeight="Bold" Foreground="#44FFFFFF" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,16,0,0"/>

                            <!-- Center Host for the Active HUD Music Control View -->
                            <Viewbox Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16">
                                <ContentControl x:Name="PreviewHost">
                                    <ContentControl.Effect>
                                        <DropShadowEffect BlurRadius="25" ShadowDepth="8" Opacity="0.5" Color="Black"/>
                                    </ContentControl.Effect>
                                </ContentControl>
                            </Viewbox>
                        </Grid>
                    </Border>

                    <!-- Bottom Close Button in the column -->
                    <Button Grid.Row="2"
                            Content="{Binding CloseText}"
                            Width="80"
                            Height="32"
                            Margin="0,20,0,0"
                            HorizontalAlignment="Right"
                            Click="CloseButton_Click"
                            Background="#2AFFFFFF"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" x:Name="Brd">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Brd" Property="Background" Value="#3DFFFFFF" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <!-- Close Button (X) at Top Right (Global) -->
                <Button Grid.Column="0" Grid.ColumnSpan="5" Click="CloseButton_Click" VerticalAlignment="Top" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="28" Height="28" Margin="0,-4,-4,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" CornerRadius="4" x:Name="Brd">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Foreground="#88FFFFFF" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="Txt"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Brd" Property="Background" Value="#2AFFFFFF" />
                                    <Setter TargetName="Txt" Property="Foreground" Value="White" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Overlay Dialog Layer -->
        <Grid x:Name="OverlayDialogs" Background="#AA000000" Panel.ZIndex="1000" Visibility="Collapsed">
            <!-- License Dialog -->
            <Border x:Name="LicenseDialog" Background="#1F1F1F" Width="520" Height="420" CornerRadius="8" BorderThickness="1" BorderBrush="#30FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.6" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding OpenSourceLicensesText}" FontSize="16" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" FontFamily="Segoe UI Variable, Segoe UI"/>
                        <Border Grid.Column="1" Background="#0DFFFFFF" CornerRadius="4" Padding="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="NoraBar" Command="{Binding SelectNoraBarLicenseCommand}" Width="80" Height="26" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent" CornerRadius="3" x:Name="Brd">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Brd" Property="Background" Value="#10FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Foreground" Value="#8AFFFFFF"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsNoraBarLicenseTab}" Value="True">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{StaticResource AccentBrush}" CornerRadius="3">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="{Binding ThirdPartyTabTitle}" Command="{Binding SelectThirdPartyLicenseCommand}" Width="100" Height="26" Cursor="Hand" Margin="2,0,0,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent" CornerRadius="3" x:Name="Brd">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Brd" Property="Background" Value="#10FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Foreground" Value="#8AFFFFFF"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsNoraBarLicenseTab}" Value="False">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{StaticResource AccentBrush}" CornerRadius="3">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBox Grid.Row="1" Text="{Binding CurrentLicenseText, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" Background="#0DFFFFFF" Foreground="#E3E3E3" BorderThickness="0" Padding="12" VerticalScrollBarVisibility="Auto" FontFamily="Consolas, Courier New" FontSize="11"/>

                    <Button Grid.Row="2" Content="{Binding CloseText}" Command="{Binding CloseLicenseCommand}" Width="80" Height="32" Margin="0,16,0,0" HorizontalAlignment="Right" Foreground="White" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#2AFFFFFF" CornerRadius="4" x:Name="Brd">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Brd" Property="Background" Value="#3DFFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Update Dialog -->
            <Border x:Name="UpdateDialog" Background="#1F1F1F" Width="400" Height="220" CornerRadius="8" BorderThickness="1" BorderBrush="#30FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.6" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding UpdateText}" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,16" FontFamily="Segoe UI Variable, Segoe UI"/>

                    <!-- 中央エリア: ステータステキストまたはスピナー -->
                    <Grid Grid.Row="1">
                        <!-- 通常のステータステキスト表示 -->
                        <TextBlock x:Name="StatusTextBlock" Text="{Binding UpdateStatus}" Foreground="White" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" FontFamily="Segoe UI Variable, Segoe UI">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCheckingUpdates}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- ローディングスピナー表示 -->
                        <StackPanel x:Name="LoadingSpinnerPanel" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCheckingUpdates}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <!-- 点線 Ellipse を回転させるスピナー -->
                            <Grid Width="36" Height="36" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Center" Margin="0,0,0,12">
                                <Grid.RenderTransform>
                                    <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                                </Grid.RenderTransform>
                                <Ellipse Stroke="#15FFFFFF" StrokeThickness="3"/>
                                <Ellipse Stroke="{StaticResource AccentBrush}" StrokeThickness="3" StrokeDashArray="3,1" StrokeDashOffset="0"/>
                                <Grid.Triggers>
                                    <EventTrigger RoutedEvent="Grid.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0" To="360" Duration="0:0:1"
                                                                 RepeatBehavior="Forever"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Grid.Triggers>
                            </Grid>
                            <TextBlock Text="{Binding UpdateStatus}" Foreground="#8AFFFFFF" FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- ボタンエリア (チェック中は非表示に) -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCheckingUpdates}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Download Button -->
                        <Button Content="{Binding DownloadText}" Command="{Binding OpenReleasePageCommand}" Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}" Width="100" Height="32" Margin="0,0,8,0" Foreground="White" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{StaticResource AccentBrush}" CornerRadius="4" x:Name="Brd">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Brd" Property="Background" Value="#005A9E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Close Button -->
                        <Button Content="{Binding CloseText}" Command="{Binding CloseUpdateDialogCommand}" Width="80" Height="32" Foreground="White" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#2AFFFFFF" CornerRadius="4" x:Name="Brd">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Brd" Property="Background" Value="#3DFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Reset Confirm Dialog -->
            <Border x:Name="ResetDialog" Background="#1F1F1F" Width="400" Height="200" CornerRadius="8" BorderThickness="1" BorderBrush="#30FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.6" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding ResetConfirmTitleText}" FontSize="16" FontWeight="SemiBold" Foreground="#FF6B6B" Margin="0,0,0,16" FontFamily="Segoe UI Variable, Segoe UI"/>

                    <TextBlock Grid.Row="1" Text="{Binding ResetConfirmMessageText}" Foreground="White" FontSize="13" VerticalAlignment="Top" TextWrapping="Wrap" FontFamily="Segoe UI Variable, Segoe UI"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="{Binding ResetConfirmNoText}" Command="{Binding CloseResetDialogCommand}" Width="80" Height="32" Margin="0,0,8,0" Foreground="White" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#2AFFFFFF" CornerRadius="4" x:Name="Brd">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Brd" Property="Background" Value="#3DFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="{Binding ResetConfirmYesText}" Command="{Binding ResetAllSettingsCommand}" Width="100" Height="32" Foreground="White" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#FF4B4B" CornerRadius="4" x:Name="Brd">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Brd" Property="Background" Value="#CC3333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

<UserControl x:Class="NoraBar.Views.Home.Design21.ClassicSystemOverlayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:NoraBar.Views.Controls">
    <Border Background="#F01A1A1A" BorderBrush="#33FFFFFF" BorderThickness="1"
            CornerRadius="12" Padding="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid Margin="0,0,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Width="48" Height="48" Margin="0,0,16,0">
                    <Border Background="#24FFFFFF" CornerRadius="4"/>
                    <TextBlock Text="&#xE93C;" FontFamily="Segoe Fluent Icons" Foreground="#88FFFFFF"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Image Source="{Binding Music.AlbumArt}" Stretch="UniformToFill"/>
                </Grid>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding MediaTitle}" Foreground="White" FontSize="15"
                                   FontWeight="SemiBold" MaxWidth="230" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding MediaArtist}" Foreground="#B3FFFFFF" FontSize="13"
                                   MaxWidth="150" Margin="12,0,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0" IsEnabled="{Binding HasMedia}">
                        <controls:IconButton IconText="&#xE892;" Width="28" Height="28"
                                             Command="{Binding Music.PreviousCommand}"/>
                        <controls:IconButton IconText="{Binding Music.IsPlaying, Converter={StaticResource PlayPauseIconConverter}}"
                                             Width="28" Height="28" Margin="8,0"
                                             Command="{Binding Music.PlayPauseCommand}"/>
                        <controls:IconButton IconText="&#xE893;" Width="28" Height="28"
                                             Command="{Binding Music.NextCommand}"/>
                        <ProgressBar Value="{Binding Music.ProgressValue}" Maximum="100" Width="120"
                                     Height="3" Margin="16,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
            <StackPanel Grid.Column="1" Margin="0,0,24,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding LocalTimeText}" Foreground="White" FontSize="28"
                           FontWeight="Light" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding LocalDateText}" Foreground="#B3FFFFFF" FontSize="12"
                           HorizontalAlignment="Center"/>
            </StackPanel>
            <Border Grid.Column="2" BorderBrush="#30FFFFFF" BorderThickness="1,0,0,0"
                    Padding="20,0,0,0" VerticalAlignment="Center">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding FirstWorldClockLabel}" Foreground="#88FFFFFF" FontSize="11"
                               Margin="0,0,14,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding FirstWorldClockTimeText}" Foreground="White"
                               FontSize="13"/>
                    <TextBlock Grid.Row="1" Text="{Binding SecondWorldClockLabel}" Foreground="#88FFFFFF"
                               FontSize="11" Margin="0,6,14,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SecondWorldClockTimeText}"
                               Foreground="White" FontSize="13" Margin="0,6,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>

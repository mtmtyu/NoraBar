<UserControl x:Class="NoraBar.Views.Home.Design22C.FusionExpressiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:NoraBar.Views.Controls">
    <Border Background="#E80A0A0A" BorderBrush="#33FFFFFF" BorderThickness="1"
            CornerRadius="24" Padding="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                <Grid Width="64" Height="64" Margin="0,0,16,0">
                    <Border Background="#35FFFFFF" CornerRadius="16"/>
                    <TextBlock Text="&#xE93C;" FontFamily="Segoe Fluent Icons" Foreground="#88FFFFFF"
                               FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Image Source="{Binding Music.AlbumArt}" Stretch="UniformToFill"/>
                </Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding MediaTitle}" Foreground="White" FontSize="16"
                               FontWeight="Bold" MaxWidth="220" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding MediaArtist}" Foreground="{StaticResource AccentBrush}"
                               FontSize="13" MaxWidth="220" TextTrimming="CharacterEllipsis"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" IsEnabled="{Binding HasMedia}">
                        <controls:IconButton IconText="&#xE892;" Width="28" Height="28"
                                             Command="{Binding Music.PreviousCommand}"/>
                        <controls:IconButton IconText="{Binding Music.IsPlaying, Converter={StaticResource PlayPauseIconConverter}}"
                                             Width="30" Height="30" Margin="10,0"
                                             Command="{Binding Music.PlayPauseCommand}"/>
                        <controls:IconButton IconText="&#xE893;" Width="28" Height="28"
                                             Command="{Binding Music.NextCommand}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <Border Grid.Column="0" BorderBrush="#1FFFFFFF" BorderThickness="0,0,1,0"
                    HorizontalAlignment="Right" Margin="0,8"/>
            <StackPanel Grid.Column="1" Margin="18,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding LocalTimeText}" Foreground="White" FontSize="24"
                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding LocalDateText}" Foreground="#A8FFFFFF" FontSize="12"
                           HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Border BorderBrush="#1FFFFFFF" BorderThickness="1,0,0,0" Margin="0,8,16,8"/>
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="{Binding FirstWorldClockLabel}" Foreground="#A8FFFFFF" FontSize="9"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding FirstWorldClockTimeText}" Foreground="White" FontSize="13"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="{Binding SecondWorldClockLabel}" Foreground="#A8FFFFFF" FontSize="9"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding SecondWorldClockTimeText}" Foreground="White" FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

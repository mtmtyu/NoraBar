<UserControl x:Class="NoraBar.Views.Home.Design20.ActivityModulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:NoraBar.Views.Controls">
    <UserControl.Resources>
        <Style x:Key="ModuleCard" TargetType="Border">
            <Setter Property="Background" Value="#11FFFFFF"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>
    </UserControl.Resources>
    <Border Style="{StaticResource IslandBorderStyle}" Padding="4">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource ModuleCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Width="40" Height="40" Margin="0,0,12,0">
                        <Border Background="#24FFFFFF" CornerRadius="8"/>
                        <TextBlock Text="&#xE93C;" FontFamily="Segoe Fluent Icons" Foreground="#88FFFFFF"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image Source="{Binding Music.AlbumArt}" Stretch="UniformToFill"/>
                    </Grid>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding MediaTitle}" Foreground="White" FontWeight="SemiBold"
                                   MaxWidth="220" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding MediaArtist}" Foreground="#A8FFFFFF" FontSize="12"
                                   MaxWidth="220" TextTrimming="CharacterEllipsis"/>
                        <ProgressBar Value="{Binding Music.ProgressValue}" Maximum="100" Height="2"
                                     Margin="0,4,0,0" IsHitTestVisible="False"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0,0,0"
                                VerticalAlignment="Center" IsEnabled="{Binding HasMedia}">
                        <controls:IconButton IconText="&#xE892;" Width="28" Height="28"
                                             Command="{Binding Music.PreviousCommand}"/>
                        <controls:IconButton IconText="{Binding Music.IsPlaying, Converter={StaticResource PlayPauseIconConverter}}"
                                             Width="28" Height="28" Margin="4,0"
                                             Command="{Binding Music.PlayPauseCommand}"/>
                        <controls:IconButton IconText="&#xE893;" Width="28" Height="28"
                                             Command="{Binding Music.NextCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource ModuleCard}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE823;" FontFamily="Segoe Fluent Icons" Foreground="#A8FFFFFF"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="{Binding LocalTimeText}" Foreground="White" FontSize="16"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding LocalDateText}" Foreground="#A8FFFFFF" FontSize="10"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource ModuleCard}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE128;" FontFamily="Segoe Fluent Icons" Foreground="#A8FFFFFF"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Text="{Binding FirstWorldClockLabel}" Foreground="#A8FFFFFF" FontSize="10"/>
                        <TextBlock Text="{Binding FirstWorldClockTimeText}" Foreground="White" FontSize="12"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{Binding SecondWorldClockLabel}" Foreground="#A8FFFFFF" FontSize="10"/>
                        <TextBlock Text="{Binding SecondWorldClockTimeText}" Foreground="White" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>

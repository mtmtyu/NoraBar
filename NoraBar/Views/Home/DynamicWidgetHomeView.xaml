<UserControl x:Class="NoraBar.Views.Home.DynamicWidgetHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource IslandBorderStyle}" Padding="12,8">
        <ScrollViewer x:Name="WidgetsScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Focusable="False">
            <WrapPanel x:Name="WidgetsContainer"
                       Orientation="Horizontal"
                       VerticalAlignment="Center"/>
        </ScrollViewer>
    </Border>
</UserControl>

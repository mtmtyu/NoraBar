<UserControl x:Class="NoraBar.Views.Home.Design22B.FusionBalancedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:NoraBar.Views.Controls">
    <Border Background="#E6101010" BorderBrush="#2AFFFFFF" BorderThickness="1"
            CornerRadius="22" Padding="12,8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid Margin="0,0,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Width="40" Height="40" Margin="0,0,12,0">
                    <Border Background="#2AFFFFFF" CornerRadius="8"/>
                    <TextBlock Text="&#xE93C;" FontFamily="Segoe Fluent Icons" Foreground="#88FFFFFF"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Image Source="{Binding Music.AlbumArt}" Stretch="UniformToFill"/>
                </Grid>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding MediaTitle}" Foreground="White" FontWeight="SemiBold"
                               MaxWidth="205" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding MediaArtist}" Foreground="#A8FFFFFF" FontSize="12"
                               MaxWidth="205" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0,0,0"
                            VerticalAlignment="Center" IsEnabled="{Binding HasMedia}">
                    <controls:IconButton IconText="&#xE892;" Width="28" Height="28"
                                         Command="{Binding Music.PreviousCommand}"/>
                    <controls:IconButton IconText="{Binding Music.IsPlaying, Converter={StaticResource PlayPauseIconConverter}}"
                                         Width="30" Height="30" Margin="6,0"
                                         Command="{Binding Music.PlayPauseCommand}"/>
                    <controls:IconButton IconText="&#xE893;" Width="28" Height="28"
                                         Command="{Binding Music.NextCommand}"/>
                </StackPanel>
            </Grid>
            <Border Grid.Column="0" BorderBrush="#1FFFFFFF" BorderThickness="0,0,1,0"
                    HorizontalAlignment="Right"/>
            <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding LocalTimeText}" Foreground="White" FontSize="18"
                           FontWeight="Medium" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding LocalDateText}" Foreground="#A8FFFFFF" FontSize="11"
                           HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Border BorderBrush="#1FFFFFFF" BorderThickness="1,0,0,0" Margin="0,4,14,4"/>
                <StackPanel Margin="0,0,14,0">
                    <TextBlock Text="{Binding FirstWorldClockLabel}" Foreground="#A8FFFFFF" FontSize="10"/>
                    <TextBlock Text="{Binding FirstWorldClockTimeText}" Foreground="White" FontSize="12"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="{Binding SecondWorldClockLabel}" Foreground="#A8FFFFFF" FontSize="10"/>
                    <TextBlock Text="{Binding SecondWorldClockTimeText}" Foreground="White" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

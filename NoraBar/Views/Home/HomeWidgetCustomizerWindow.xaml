<Window x:Class="NoraBar.Views.Home.HomeWidgetCustomizerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding TitleText}" Width="760" Height="680"
        WindowStartupLocation="CenterOwner" Background="Transparent" Foreground="White"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize"
        FontFamily="Segoe UI, Yu Gothic UI, Meiryo"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Card Style -->
        <Style x:Key="CustomizerCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#0DFFFFFF" />
            <Setter Property="BorderBrush" Value="#15FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <!-- Header Style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, Yu Gothic UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F5F5F5" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </Window.Resources>

    <!-- Root Border matching SettingsWindow -->
    <Border x:Name="RootBorder" CornerRadius="12" Background="#18181F" BorderBrush="#30FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="8" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/AppIcon.ico" Width="28" Height="28" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding HeaderText}" FontSize="18" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI Variable Display, Segoe UI"/>
                        <TextBlock Text="{Binding HeaderDescriptionText}" FontSize="11" Foreground="#8A8A8A" Margin="0,2,0,0" FontFamily="Segoe UI Variable Text, Segoe UI"/>
                    </StackPanel>
                </StackPanel>

                <Button Content="&#xE711;" FontFamily="Segoe Fluent Icons" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="CloseButton_Click" Background="Transparent" Foreground="#A8FFFFFF" BorderThickness="0" FontSize="14" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Width="28" Height="28" x:Name="Brd">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Brd" Property="Background" Value="#25FFFFFF"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Live HUD Preview Section -->
            <Border Grid.Row="1" Background="#0AFFFFFF" BorderBrush="#1CFFFFFF" BorderThickness="1" CornerRadius="12" Padding="16,12" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="&#xE890;" FontFamily="Segoe Fluent Icons" Foreground="#FF64B5F6" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding LivePreviewText}" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                    </StackPanel>
                    <!-- Preview Host Content Container -->
                    <Border Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="4" Margin="0,0,0,8">
                        <ContentControl x:Name="LivePreviewHost"/>
                    </Border>
                    <!-- Max Size Controls -->
                    <Grid Grid.Row="2" Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <Grid Margin="0,0,0,2">
                                <TextBlock Text="Max Width / 最大幅" FontSize="11" Foreground="#A0FFFFFF" HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding MaxWidgetWidth, StringFormat={}{0:F0} px}" FontSize="11" Foreground="#FF64B5F6" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Slider Minimum="300" Maximum="1400" TickFrequency="10" IsSnapToTickEnabled="True" Value="{Binding MaxWidgetWidth, Mode=TwoWay}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <Grid Margin="0,0,0,2">
                                <TextBlock Text="Max Height / 最大高さ" FontSize="11" Foreground="#A0FFFFFF" HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding MaxWidgetHeight, StringFormat={}{0:F0} px}" FontSize="11" Foreground="#FF64B5F6" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Slider Minimum="100" Maximum="800" TickFrequency="10" IsSnapToTickEnabled="True" Value="{Binding MaxWidgetHeight, Mode=TwoWay}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Main Content Area (Active Widgets & Catalog) -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1.0*"/>
                </Grid.ColumnDefinitions>

                <!-- Active Widgets Column -->
                <Grid Grid.Column="0" Margin="0,0,14,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding ActiveWidgetsHeaderText}" Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Grid.Row="1" Background="#0D1117" CornerRadius="10" BorderBrush="#1AFFFFFF" BorderThickness="1" Padding="6">
                        <ListBox x:Name="ActiveWidgetsListBox" ItemsSource="{Binding ActiveWidgets}" Background="Transparent" BorderThickness="0"
                                 PreviewMouseLeftButtonDown="ActiveWidgets_PreviewMouseLeftButtonDown"
                                 PreviewMouseMove="ActiveWidgets_PreviewMouseMove"
                                 PreviewMouseLeftButtonUp="ActiveWidgets_PreviewMouseLeftButtonUp">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CustomizerCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Drag Handle Icon -->
                                            <TextBlock Grid.Column="0" Text="&#xE700;" FontFamily="Segoe Fluent Icons" Foreground="#8AFFFFFF" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0" Cursor="SizeAll"/>

                                            <!-- Widget Title & Icon -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding IconText}" FontFamily="Segoe Fluent Icons" Foreground="#FF64B5F6" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Move / Delete Actions -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="&#xE74A;" FontFamily="Segoe Fluent Icons" Click="MoveUp_Click" Margin="2,0" Background="Transparent" Foreground="#A0FFFFFF" BorderThickness="0" Cursor="Hand" Width="24" Height="24"/>
                                                <Button Content="&#xE74B;" FontFamily="Segoe Fluent Icons" Click="MoveDown_Click" Margin="2,0" Background="Transparent" Foreground="#A0FFFFFF" BorderThickness="0" Cursor="Hand" Width="24" Height="24"/>
                                                <Button Content="&#xE74D;" FontFamily="Segoe Fluent Icons" Command="{Binding DataContext.RemoveWidgetCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="4,0,0,0" Background="Transparent" Foreground="#FFEF5350" BorderThickness="0" Cursor="Hand" Width="24" Height="24"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>

                <!-- Catalog Column -->
                <Grid Grid.Column="1" Margin="14,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding AddWidgetsHeaderText}" Style="{StaticResource SectionHeaderStyle}"/>
                    <Border Grid.Row="1" Background="#0D1117" CornerRadius="10" BorderBrush="#1AFFFFFF" BorderThickness="1" Padding="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding CatalogWidgets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CustomizerCardStyle}">
                                            <Grid>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding IconText}" FontFamily="Segoe Fluent Icons" Foreground="#FF81D4FA" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Medium" FontSize="12" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button Content="{Binding DataContext.AddWidgetButtonText, RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.AddWidgetCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                                        HorizontalAlignment="Right" VerticalAlignment="Center" Padding="8,3" Background="#FF64B5F6" Foreground="Black" FontWeight="Bold" FontSize="11" BorderThickness="0" Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <!-- Footer Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="{Binding CancelButtonText}" Click="CancelButton_Click" Width="90" Height="32" Margin="0,0,10,0" Foreground="White" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#2AFFFFFF" CornerRadius="4" x:Name="Brd">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Brd" Property="Background" Value="#3DFFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="{Binding SaveAndApplyButtonText}" Click="SaveButton_Click" Width="110" Height="32" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#FF64B5F6" CornerRadius="4" x:Name="Brd">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Brd" Property="Background" Value="#FF90CAF9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>

<Window x:Class="NoraBar.Views.Home.HomeWidgetCustomizerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:NoraBar.Views.Controls"
        Title="Home HUD Widget Customizer" Width="680" Height="520"
        WindowStartupLocation="CenterOwner" Background="#18181C" Foreground="White"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize">
    <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="12" Background="#1E1E24">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8B9;" FontFamily="Segoe Fluent Icons" FontSize="20" Foreground="#FF64B5F6" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Widget Layout Customizer" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="&#xE711;" FontFamily="Segoe Fluent Icons" HorizontalAlignment="Right" Click="CloseButton_Click"
                        Background="Transparent" Foreground="#A8FFFFFF" BorderThickness="0" FontSize="14" Cursor="Hand"/>
            </Grid>

            <!-- Main Content Grid -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Active Widgets Section -->
                <TextBlock Grid.Row="0" Text="Active Widgets (Drag to Reorder)" FontSize="13" FontWeight="SemiBold" Foreground="#A8FFFFFF" Margin="0,0,0,8"/>
                <Border Grid.Row="1" Background="#121216" CornerRadius="8" BorderBrush="#25FFFFFF" BorderThickness="1" Padding="8">
                    <ListBox x:Name="ActiveWidgetsListBox" ItemsSource="{Binding ActiveWidgets}" Background="Transparent" BorderThickness="0"
                             AllowDrop="True" PreviewMouseLeftButtonDown="ActiveWidgets_PreviewMouseLeftButtonDown"
                             Drop="ActiveWidgets_Drop" DragOver="ActiveWidgets_DragOver">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Padding" Value="4"/>
                                <Setter Property="Background" Value="#1AFFFFFF"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Drag Handle -->
                                    <TextBlock Text="&#xE700;" FontFamily="Segoe Fluent Icons" Foreground="#66FFFFFF" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0" Cursor="SizeAll"/>

                                    <!-- Widget Info -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding IconText}" FontFamily="Segoe Fluent Icons" Foreground="#FF64B5F6" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Style Selector -->
                                    <ComboBox Grid.Column="2" ItemsSource="{Binding AvailableStyles}" SelectedItem="{Binding Style, Mode=TwoWay}"
                                              Width="160" Margin="10,0" VerticalAlignment="Center" Background="#2AFFFFFF" Foreground="Black"/>

                                    <!-- Action Buttons -->
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="&#xE74A;" FontFamily="Segoe Fluent Icons" Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="2,0" Background="Transparent" Foreground="#CCFFFFFF" BorderThickness="0" Cursor="Hand"/>
                                        <Button Content="&#xE74B;" FontFamily="Segoe Fluent Icons" Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="2,0" Background="Transparent" Foreground="#CCFFFFFF" BorderThickness="0" Cursor="Hand"/>
                                        <Button Content="&#xE74D;" FontFamily="Segoe Fluent Icons" Command="{Binding DataContext.RemoveWidgetCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="6,0,2,0" Background="Transparent" Foreground="#FFEF5350" BorderThickness="0" Cursor="Hand"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- Catalog Section -->
                <TextBlock Grid.Row="2" Text="Add Available Widgets" FontSize="13" FontWeight="SemiBold" Foreground="#A8FFFFFF" Margin="0,16,0,8"/>
                <ItemsControl Grid.Row="3" ItemsSource="{Binding CatalogWidgets}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1AFFFFFF" CornerRadius="8" Margin="4" Padding="10">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding IconText}" FontFamily="Segoe Fluent Icons" Foreground="#FF81D4FA" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Medium" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Content="Add" Command="{Binding DataContext.AddWidgetCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                            HorizontalAlignment="Right" VerticalAlignment="Center" Padding="10,4" Background="#FF64B5F6" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- Footer Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Click="CancelButton_Click" Width="90" Height="32" Margin="0,0,10,0" Background="#2AFFFFFF" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Save &amp; Apply" Click="SaveButton_Click" Width="110" Height="32" Background="#FF64B5F6" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

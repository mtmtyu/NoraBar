<UserControl x:Class="NoraBar.Views.Home.Widgets.SystemStatusWidgetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Minimal Text Style -->
        <DataTemplate x:Key="SystemMinimalTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,2">
                <Border Background="#2581C483" CornerRadius="4" Padding="4,2" Margin="0,0,6,0">
                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe Fluent Icons" Foreground="#FF81C483" FontSize="12" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="SYS READY" Foreground="White" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" FontFamily="Segoe UI Variable Text, Segoe UI"/>
            </StackPanel>
        </DataTemplate>

        <!-- Gauge Progress Style -->
        <DataTemplate x:Key="SystemGaugeTemplate">
            <Border Background="#1CFFFFFF" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="10" Padding="12,6" Margin="4,2">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="26" Height="26" Margin="0,0,8,0">
                        <Ellipse Stroke="#30FFFFFF" StrokeThickness="3"/>
                        <Ellipse Stroke="#FF81C483" StrokeThickness="3" StrokeDashArray="3,1"/>
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe Fluent Icons" Foreground="#FF81C483" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SYSTEM ACTIVE" Foreground="#FF81C483" FontSize="9" FontWeight="Bold" FontFamily="Segoe UI Variable Display, Segoe UI"/>
                        <TextBlock Text="Operational" Foreground="#D0FFFFFF" FontSize="11" FontWeight="Medium" FontFamily="Segoe UI Variable Text, Segoe UI"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ContentControl x:Name="SystemContentControl" Content="{Binding}"/>
</UserControl>

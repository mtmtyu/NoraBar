<UserControl x:Class="NoraBar.Views.Home.Widgets.SystemStatusWidgetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Minimal Text Style -->
        <DataTemplate x:Key="SystemMinimalTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                <TextBlock Text="&#xE9D9;" FontFamily="Segoe Fluent Icons" Foreground="#A8FFFFFF" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock Text="SYS OK" Foreground="White" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <!-- Gauge Progress Style -->
        <DataTemplate x:Key="SystemGaugeTemplate">
            <Border Background="#25FFFFFF" CornerRadius="8" Padding="10,6" Margin="4,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="24" Height="24" Margin="0,0,8,0">
                        <Ellipse Stroke="#40FFFFFF" StrokeThickness="3"/>
                        <Ellipse Stroke="#FF81C483" StrokeThickness="3" StrokeDashArray="3,1"/>
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe Fluent Icons" Foreground="#FF81C483" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ACTIVE" Foreground="#FF81C483" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="100% Ready" Foreground="#D0FFFFFF" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ContentControl x:Name="SystemContentControl" Content="{Binding}"/>
</UserControl>

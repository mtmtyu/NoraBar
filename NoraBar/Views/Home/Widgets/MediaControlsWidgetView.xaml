<UserControl x:Class="NoraBar.Views.Home.Widgets.MediaControlsWidgetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:NoraBar.Views.Controls">
    <UserControl.Resources>
        <!-- Compact Style Template -->
        <DataTemplate x:Key="MediaCompactTemplate">
            <Grid Margin="4,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Width="34" Height="34" Margin="0,0,8,0">
                    <Border Background="#25FFFFFF" CornerRadius="8">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.3" Color="Black"/>
                        </Border.Effect>
                    </Border>
                    <TextBlock Text="&#xE93C;" FontFamily="Segoe Fluent Icons" Foreground="#88FFFFFF"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Border CornerRadius="8">
                        <Border.OpacityMask>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Border Width="34" Height="34" CornerRadius="8" Background="Black"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Border.OpacityMask>
                        <Image Source="{Binding Music.AlbumArt}" Stretch="UniformToFill"/>
                    </Border>
                </Grid>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding MediaTitle}" Foreground="White" FontWeight="SemiBold"
                               FontSize="13" MaxWidth="150" TextTrimming="CharacterEllipsis" FontFamily="Segoe UI Variable Text, Segoe UI"/>
                    <TextBlock Text="{Binding MediaArtist}" Foreground="#A8FFFFFF" FontSize="11"
                               MaxWidth="150" TextTrimming="CharacterEllipsis" FontFamily="Segoe UI Variable Text, Segoe UI"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0"
                            VerticalAlignment="Center" IsEnabled="{Binding HasMedia}">
                    <controls:IconButton IconText="{Binding Music.IsPlaying, Converter={StaticResource PlayPauseIconConverter}}"
                                         Width="28" Height="28"
                                         Command="{Binding Music.PlayPauseCommand}"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Artwork Cover Hover Template (Default / Medium) -->
        <DataTemplate x:Key="MediaArtworkHoverTemplate">
            <Border x:Name="RootCard" Width="190" Height="105" CornerRadius="10" Background="#1E1E2E" Margin="4,2" ClipToBounds="True">
                <Border.OpacityMask>
                    <VisualBrush Stretch="None">
                        <VisualBrush.Visual>
                            <Border Width="190" Height="105" CornerRadius="10" Background="Black"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Border.OpacityMask>
                <Grid ClipToBounds="True">
                    <Grid>
                        <TextBlock Text="&#xE93C;" FontFamily="Segoe Fluent Icons" Foreground="#33FFFFFF"
                                   FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image Source="{Binding Music.AlbumArt}" Stretch="UniformToFill"/>
                        <Border VerticalAlignment="Bottom" Height="70">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00000000" Offset="0"/>
                                    <GradientStop Color="#B0000000" Offset="0.5"/>
                                    <GradientStop Color="#E6000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>

                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Margin="10,0,10,6">
                        <StackPanel.RenderTransform>
                            <TranslateTransform Y="38"/>
                        </StackPanel.RenderTransform>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=RootCard}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                     To="0" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                     To="38" Duration="0:0:0.20">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseIn"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="{Binding MediaTitle}" Foreground="White" FontWeight="Bold"
                                       FontSize="13" MaxWidth="170" TextTrimming="CharacterEllipsis"
                                       FontFamily="Segoe UI Variable Text, Segoe UI">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="{Binding MediaArtist}" Foreground="#E0FFFFFF" FontSize="11"
                                       MaxWidth="170" TextTrimming="CharacterEllipsis"
                                       FontFamily="Segoe UI Variable Text, Segoe UI">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="32"
                                    Background="Transparent" IsEnabled="{Binding HasMedia}">
                            <controls:IconButton IconText="&#xE892;" Width="28" Height="28" Margin="6,0"
                                                 Command="{Binding Music.SkipPreviousCommand}"/>
                            <controls:IconButton IconText="{Binding Music.IsPlaying, Converter={StaticResource PlayPauseIconConverter}}"
                                                 Width="32" Height="32" Margin="6,0"
                                                 Command="{Binding Music.PlayPauseCommand}"/>
                            <controls:IconButton IconText="&#xE893;" Width="28" Height="28" Margin="6,0"
                                                 Command="{Binding Music.SkipNextCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Artwork Cover Hover Template (Small: 150 x 85) -->
        <DataTemplate x:Key="MediaArtworkHoverSmallTemplate">
            <Border x:Name="RootCard" Width="150" Height="85" CornerRadius="8" Background="#1E1E2E" Margin="4,2" ClipToBounds="True">
                <Border.OpacityMask>
                    <VisualBrush Stretch="None">
                        <VisualBrush.Visual>
                            <Border Width="150" Height="85" CornerRadius="8" Background="Black"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Border.OpacityMask>
                <Grid ClipToBounds="True">
                    <Grid>
                        <TextBlock Text="&#xE93C;" FontFamily="Segoe Fluent Icons" Foreground="#33FFFFFF"
                                   FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image Source="{Binding Music.AlbumArt}" Stretch="UniformToFill"/>
                        <Border VerticalAlignment="Bottom" Height="55">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00000000" Offset="0"/>
                                    <GradientStop Color="#B0000000" Offset="0.5"/>
                                    <GradientStop Color="#E6000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>

                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Margin="8,0,8,4">
                        <StackPanel.RenderTransform>
                            <TranslateTransform Y="30"/>
                        </StackPanel.RenderTransform>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=RootCard}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                     To="0" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                     To="30" Duration="0:0:0.20">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseIn"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Text="{Binding MediaTitle}" Foreground="White" FontWeight="Bold"
                                       FontSize="11" MaxWidth="134" TextTrimming="CharacterEllipsis"
                                       FontFamily="Segoe UI Variable Text, Segoe UI">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="{Binding MediaArtist}" Foreground="#E0FFFFFF" FontSize="10"
                                       MaxWidth="134" TextTrimming="CharacterEllipsis"
                                       FontFamily="Segoe UI Variable Text, Segoe UI">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="26"
                                    Background="Transparent" IsEnabled="{Binding HasMedia}">
                            <controls:IconButton IconText="&#xE892;" Width="24" Height="24" Margin="3,0"
                                                 Command="{Binding Music.SkipPreviousCommand}"/>
                            <controls:IconButton IconText="{Binding Music.IsPlaying, Converter={StaticResource PlayPauseIconConverter}}"
                                                 Width="26" Height="26" Margin="3,0"
                                                 Command="{Binding Music.PlayPauseCommand}"/>
                            <controls:IconButton IconText="&#xE893;" Width="24" Height="24" Margin="3,0"
                                                 Command="{Binding Music.SkipNextCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Artwork Cover Hover Template (Medium: 190 x 105) -->
        <DataTemplate x:Key="MediaArtworkHoverMediumTemplate">
            <Border x:Name="RootCard" Width="190" Height="105" CornerRadius="10" Background="#1E1E2E" Margin="4,2" ClipToBounds="True">
                <Border.OpacityMask>
                    <VisualBrush Stretch="None">
                        <VisualBrush.Visual>
                            <Border Width="190" Height="105" CornerRadius="10" Background="Black"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Border.OpacityMask>
                <Grid ClipToBounds="True">
                    <Grid>
                        <TextBlock Text="&#xE93C;" FontFamily="Segoe Fluent Icons" Foreground="#33FFFFFF"
                                   FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image Source="{Binding Music.AlbumArt}" Stretch="UniformToFill"/>
                        <Border VerticalAlignment="Bottom" Height="70">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00000000" Offset="0"/>
                                    <GradientStop Color="#B0000000" Offset="0.5"/>
                                    <GradientStop Color="#E6000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>

                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Margin="10,0,10,6">
                        <StackPanel.RenderTransform>
                            <TranslateTransform Y="38"/>
                        </StackPanel.RenderTransform>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=RootCard}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                     To="0" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                     To="38" Duration="0:0:0.20">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseIn"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="{Binding MediaTitle}" Foreground="White" FontWeight="Bold"
                                       FontSize="13" MaxWidth="170" TextTrimming="CharacterEllipsis"
                                       FontFamily="Segoe UI Variable Text, Segoe UI">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="{Binding MediaArtist}" Foreground="#E0FFFFFF" FontSize="11"
                                       MaxWidth="170" TextTrimming="CharacterEllipsis"
                                       FontFamily="Segoe UI Variable Text, Segoe UI">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="32"
                                    Background="Transparent" IsEnabled="{Binding HasMedia}">
                            <controls:IconButton IconText="&#xE892;" Width="28" Height="28" Margin="6,0"
                                                 Command="{Binding Music.SkipPreviousCommand}"/>
                            <controls:IconButton IconText="{Binding Music.IsPlaying, Converter={StaticResource PlayPauseIconConverter}}"
                                                 Width="32" Height="32" Margin="6,0"
                                                 Command="{Binding Music.PlayPauseCommand}"/>
                            <controls:IconButton IconText="&#xE893;" Width="28" Height="28" Margin="6,0"
                                                 Command="{Binding Music.SkipNextCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Artwork Cover Hover Template (Large: 240 x 135) -->
        <DataTemplate x:Key="MediaArtworkHoverLargeTemplate">
            <Border x:Name="RootCard" Width="240" Height="135" CornerRadius="12" Background="#1E1E2E" Margin="4,2" ClipToBounds="True">
                <Border.OpacityMask>
                    <VisualBrush Stretch="None">
                        <VisualBrush.Visual>
                            <Border Width="240" Height="135" CornerRadius="12" Background="Black"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Border.OpacityMask>
                <Grid ClipToBounds="True">
                    <Grid>
                        <TextBlock Text="&#xE93C;" FontFamily="Segoe Fluent Icons" Foreground="#33FFFFFF"
                                   FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image Source="{Binding Music.AlbumArt}" Stretch="UniformToFill"/>
                        <Border VerticalAlignment="Bottom" Height="90">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00000000" Offset="0"/>
                                    <GradientStop Color="#B0000000" Offset="0.5"/>
                                    <GradientStop Color="#E6000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>

                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Margin="14,0,14,8">
                        <StackPanel.RenderTransform>
                            <TranslateTransform Y="44"/>
                        </StackPanel.RenderTransform>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=RootCard}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                     To="0" Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                     To="44" Duration="0:0:0.20">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseIn"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="{Binding MediaTitle}" Foreground="White" FontWeight="Bold"
                                       FontSize="15" MaxWidth="212" TextTrimming="CharacterEllipsis"
                                       FontFamily="Segoe UI Variable Text, Segoe UI">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="{Binding MediaArtist}" Foreground="#E0FFFFFF" FontSize="12"
                                       MaxWidth="212" TextTrimming="CharacterEllipsis"
                                       FontFamily="Segoe UI Variable Text, Segoe UI">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="38"
                                    Background="Transparent" IsEnabled="{Binding HasMedia}">
                            <controls:IconButton IconText="&#xE892;" Width="34" Height="34" Margin="8,0"
                                                 Command="{Binding Music.SkipPreviousCommand}"/>
                            <controls:IconButton IconText="{Binding Music.IsPlaying, Converter={StaticResource PlayPauseIconConverter}}"
                                                 Width="38" Height="38" Margin="8,0"
                                                 Command="{Binding Music.PlayPauseCommand}"/>
                            <controls:IconButton IconText="&#xE893;" Width="34" Height="34" Margin="8,0"
                                                 Command="{Binding Music.SkipNextCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Artwork Blur & 3-Line Lyrics Template -->
        <DataTemplate x:Key="MediaBlurLyricsTemplate">
            <Border x:Name="RootCard" Width="280" Height="130" CornerRadius="12" Background="#1E1E2E" Margin="4,2" ClipToBounds="True">
                <Border.OpacityMask>
                    <VisualBrush Stretch="None">
                        <VisualBrush.Visual>
                            <Border Width="280" Height="130" CornerRadius="12" Background="Black"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Border.OpacityMask>
                <Grid ClipToBounds="True">
                    <!-- Blur Artwork Background -->
                    <Grid>
                        <TextBlock Text="&#xE93C;" FontFamily="Segoe Fluent Icons" Foreground="#22FFFFFF"
                                   FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image Source="{Binding Music.AlbumArt}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Effect>
                                <BlurEffect Radius="25"/>
                            </Image.Effect>
                        </Image>
                        <!-- Dark Overlay -->
                        <Border Background="#A00B0D19"/>
                    </Grid>

                    <!-- Center: 3-Line Synced Lyrics -->
                    <Grid VerticalAlignment="Center" Margin="12,6,12,36" Height="68">
                        <ListBox x:Name="LyricsListBoxBlur"
                                 ItemsSource="{Binding Music.LyricsList}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.CanContentScroll="True"
                                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 VirtualizingPanel.ScrollUnit="Pixel"
                                 Focusable="False"
                                 HorizontalContentAlignment="Stretch"
                                 IsHitTestVisible="False">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Text}" 
                                               TextAlignment="Center" 
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,3"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Foreground" Value="#66FFFFFF"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                        <Setter Property="FontSize" Value="13"/>
                                                        <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="{Binding Music.CurrentLyric}"
                                   Foreground="#AAFFFFFF"
                                   FontSize="12"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Music.LyricsList.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Bottom Bar: Bottom-Left Track Info, Bottom-Right Media Controls -->
                    <Grid VerticalAlignment="Bottom" Margin="10,0,10,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Bottom Left: Small Rounded Album Art + Title & Artist -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="34" Height="34" CornerRadius="6" ClipToBounds="True" Background="#20FFFFFF" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Image Source="{Binding Music.AlbumArt}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding MediaTitle}" Foreground="White" FontWeight="SemiBold"
                                           FontSize="12" MaxWidth="120" TextTrimming="CharacterEllipsis" FontFamily="Segoe UI Variable Text, Segoe UI"/>
                                <TextBlock Text="{Binding MediaArtist}" Foreground="#A8FFFFFF" FontSize="10"
                                           MaxWidth="120" TextTrimming="CharacterEllipsis" FontFamily="Segoe UI Variable Text, Segoe UI"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Bottom Right: Playback Controls -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" IsEnabled="{Binding HasMedia}">
                            <controls:IconButton IconText="&#xE892;" Width="26" Height="26" Margin="0,0,4,0" Command="{Binding Music.PreviousCommand}"/>
                            <controls:IconButton IconText="{Binding Music.IsPlaying, Converter={StaticResource PlayPauseIconConverter}}" Width="28" Height="28" Margin="0,0,4,0" Command="{Binding Music.PlayPauseCommand}"/>
                            <controls:IconButton IconText="&#xE893;" Width="26" Height="26" Command="{Binding Music.NextCommand}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ContentControl x:Name="MediaContentControl" Content="{Binding}"/>
</UserControl>

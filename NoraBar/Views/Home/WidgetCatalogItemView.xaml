<UserControl x:Class="NoraBar.Views.Home.WidgetCatalogItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="CardBorder" Background="#20FFFFFF" BorderBrush="#35FFFFFF" BorderThickness="1" CornerRadius="10" Padding="8" Margin="0,0,10,0" Width="190" Height="110">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Card Header: Icon + Title + (+) Button -->
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding IconText}" FontFamily="Segoe Fluent Icons" Foreground="#FF81D4FA" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                </StackPanel>
                <Button Content="+" Click="AddButton_Click" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="#4064B5F6" Foreground="White" FontWeight="Bold" FontSize="12" Width="20" Height="20" BorderThickness="0" Cursor="Hand" ToolTip="Add Widget">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Card Body: Scaled Real Miniature Preview -->
            <Border Grid.Row="1" Background="#15000000" CornerRadius="6" ClipToBounds="True" Padding="4">
                <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ContentControl x:Name="PreviewContentHost"/>
                </Viewbox>
            </Border>
        </Grid>
    </Border>
</UserControl>

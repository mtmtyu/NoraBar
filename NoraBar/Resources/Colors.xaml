<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackground">#F3F6FA</Color>
    <Color x:Key="AppBackground2">#EEF3F8</Color>
    <Color x:Key="AppBackground3">#E8ECF5</Color>
    <Color x:Key="IslandBackground">#050506</Color>
    <Color x:Key="IslandBackground2">#0B0B0D</Color>
    <Color x:Key="PanelBackground">#80000000</Color>
    <Color x:Key="CardBackground">#1AFFFFFF</Color>
    <Color x:Key="BorderColor">#33FFFFFF</Color>
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#80FFFFFF</Color>
    <Color x:Key="AccentColor">#0078D4</Color>
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FF9800</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackground}" />
    <SolidColorBrush x:Key="IslandBackgroundBrush" Color="{StaticResource IslandBackground}" />
    <SolidColorBrush x:Key="IslandBackground2Brush" Color="{StaticResource IslandBackground2}" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackground}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />

    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0078D4" Offset="0" />
        <GradientStop Color="#8A2BE2" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>

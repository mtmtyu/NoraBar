<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <FontFamily x:Key="DefaultFontFamily">Segoe UI Variable, Segoe UI, sans-serif</FontFamily>
    
    <Style x:Key="TextBase" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DefaultFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>
    
    <Style x:Key="TitleText" TargetType="TextBlock" BasedOn="{StaticResource TextBase}">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    
    <Style x:Key="BodyText" TargetType="TextBlock" BasedOn="{StaticResource TextBase}">
        <Setter Property="FontSize" Value="14" />
    </Style>
    
    <Style x:Key="CaptionText" TargetType="TextBlock" BasedOn="{StaticResource TextBase}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>
</ResourceDictionary>

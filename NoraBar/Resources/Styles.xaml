<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="IslandBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource IslandBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="20" ShadowDepth="10" Opacity="0.4" Color="Black" />
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="GlassCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>
</ResourceDictionary>
